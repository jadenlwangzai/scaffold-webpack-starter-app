{
  "name": "webpack-starter-app",
  "version": "2.0.0",
  "description": "A scaffold for using webpack to build apps",
  "keywords": [
    "scaffold",
    "webpack",
    "react",
    "typescript",
    "swc",
    "app"
  ],
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "dev": "cross-env NODE_ENV=development webpack serve --config webpack.config.dev.js --progress",
    "dev:test": "cross-env NODE_ENV=test webpack serve --config webpack.config.dev.js --progress",
    "dev:uat": "cross-env NODE_ENV=uat webpack serve --config webpack.config.dev.js --progress",
    "build": "rimraf dist && cross-env NODE_ENV=production webpack --config webpack.config.prod.js --progress",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "stylelint": "stylelint 'src/**/*.{css,less}'",
    "stylelint:fix": "stylelint 'src/**/*.{css,less}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,less,css}'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "author": "Jaden.W <jaden_wong@icloud.com>",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^19.0.3",
    "@commitlint/config-conventional": "^19.0.3",
    "@eslint/js": "^9.0.0",
    "@swc/core": "^1.10.0",
    "@swc/jest": "^0.2.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.21",
    "commitizen": "^4.3.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "cssnano": "^7.0.6",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "html-webpack-plugin": "^5.6.3",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "less": "^4.3.0",
    "less-loader": "^12.2.0",
    "lint-staged": "^15.5.1",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss-import": "^16.1.0",
    "postcss-loader": "^8.1.1",
    "postcss-preset-env": "^10.1.5",
    "postcss-safe-parser": "^7.0.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "style-loader": "^4.0.0",
    "stylelint": "^16.18.0",
    "stylelint-config-standard": "^37.0.0",
    "swc-loader": "^0.2.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "webpack": "^5.99.5",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "last 2 versions",
    "not dead",
    "> 0.2%"
  ],
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
